generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model User {
  id                     String       @id @default(cuid())
  email                  String       @unique
  emailVerified          DateTime?
  // bcrypt hash for email/password accounts. Null for OAuth-only users
  // (Google sign-ins that never set a password). A user with a Google
  // Account row AND a passwordHash has linked both auth methods.
  passwordHash           String?
  // Random token issued during the forgot-password flow. Cleared on
  // use or on natural expiry. @unique so the lookup in the reset
  // handler is indexed without a composite.
  resetToken             String?      @unique
  resetTokenExpires      DateTime?
  name                   String?
  image                  String?
  avatarUrl              String?
  stripeCustomerId       String?
  stripeSubscriptionId   String?
  stripeCurrentPeriodEnd DateTime?
  subscriptionStatus     String       @default("TRIAL")
  trialEndsAt            DateTime?
  timezone               String       @default("America/Chicago")
  reminderTime           String       @default("21:00")
  pushToken              String?
  // Granted manually via direct DB update (UPDATE "User" SET "isAdmin" = true WHERE email = '...').
  // Not self-service. Gates /admin/dashboard + /api/admin/*.
  isAdmin                Boolean      @default(false)
  // Color-scheme preference. Null (default) → follow system / localStorage
  // whatever next-themes picks up. Set to "light" or "dark" when the
  // user explicitly picks via the toggle; we persist to the DB so the
  // preference survives across devices without relying on localStorage.
  theme                  String?
  // Streak tracking — incremented by the Inngest process-entry pipeline
  // after a successful recording persists. Day boundaries evaluated in
  // the user's `timezone` via date-fns-tz (same-day = no change,
  // next-calendar-day = +1, gap of 2+ days = reset to 1). Full rules in
  // apps/web/src/lib/streak.ts.
  currentStreak          Int          @default(0)
  longestStreak          Int          @default(0)
  lastSessionDate        DateTime?
  // Highest milestone we've celebrated for this user (7, 30, 100). NULL
  // means no milestone fired yet. Set once and monotonically increases —
  // a user who drops from 100 back to 0 and climbs again gets a new
  // milestone toast only if they exceed lastMilestone.
  lastStreakMilestone    Int?
  // Cookie/analytics consent record — stored as JSON so we can evolve
  // the categories without a migration. Shape: { version:1, acceptedAt,
  // analytics:boolean, marketing:boolean }. Null = user has never seen
  // the banner or logged-in-from-another-device. Mirror of the
  // localStorage record on the client.
  cookieConsent          Json?
  createdAt              DateTime     @default(now())
  accounts               Account[]
  sessions               Session[]
  entries                Entry[]
  tasks                  Task[]
  goals                  Goal[]
  weeklyReports          WeeklyReport[]
  lifemapAreas           LifeMapArea[]
  memory                 UserMemory?
  lifeAudits             LifeAudit[]
  onboarding             UserOnboarding?
}

// Tombstone for deleted accounts — closes the trial-reset exploit
// documented as pentest T-07 in docs/PENTEST_RESULTS.md. On account
// deletion we write this row BEFORE cascading the User delete so a
// subsequent signup with the same email can be looked up and the
// trial policy adjusted.
//
// Retention policy (see apps/web/src/lib/bootstrap-user.ts::issueTrial):
//   - Seen within 90 days → 3-day re-trial
//   - Seen >90 days ago   → fresh 14-day trial
//   - Never seen          → fresh 14-day trial (first-timer)
//
// No FK to User (the point is that the User is gone). Email is the
// only stable identifier.
model DeletedUser {
  email                String   @id
  deletedAt            DateTime @default(now())
  originalCreatedAt    DateTime
  originalTrialEndedAt DateTime?
}

// 8-step post-signup onboarding flow. One row per user; survives
// account deletion via cascade. Completed users are identified by
// `completedAt != null` — the dashboard uses this to decide whether
// to redirect new users into the flow. See apps/web/src/app/onboarding/
// for the UI scaffold.
model UserOnboarding {
  id                     String    @id @default(cuid())
  userId                 String    @unique
  user                   User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  // Last step the user reached. 1-indexed. When completedAt is set
  // this also carries the final step number for auditing.
  currentStep            Int       @default(1)
  // Null until the user finishes step 8 (or hits Skip on the last
  // skippable step). Non-null means "don't redirect into onboarding
  // anymore".
  completedAt            DateTime?
  // Step 5 — mood baseline (one of GREAT|GOOD|NEUTRAL|LOW|ROUGH).
  // Seeds the Life Matrix starting scores so day-1 insights aren't
  // drawing against a zero baseline.
  moodBaseline           String?
  // Step 6 — user's ranked importance for the 6 canonical life areas.
  // Stored as Json: { CAREER: 3, HEALTH: 5, RELATIONSHIPS: 4, ... }
  // where higher numbers = higher importance (1-5 scale).
  lifeAreaPriorities     Json?
  // Step 2 — where they found Acuity. Free-text, short list. Drives
  // PostHog attribution (signupSource property on trial_started).
  referralSource         String?
  // Step 7 — expected weekly cadence. "DAILY" | "WEEKDAYS" | "WEEKLY"
  // | "UNSURE". Informs the post-trial email copy + reminder default.
  expectedUsageFrequency String?
  // Step 4 — did the user grant microphone permission during the
  // walkthrough? False doesn't block completion (they can grant later
  // from Settings) but we track it so the dashboard can nudge.
  microphoneGranted      Boolean   @default(false)
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt
}

model Entry {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  // DEPRECATED: use audioPath. Will remove in Inngest PR 4 once the sync
  // path is retired. Sync path writes a signed URL here; async path leaves
  // this null and writes the object path to audioPath instead.
  audioUrl      String?
  // Supabase Storage object path, e.g. "voice-entries/${userId}/${entryId}.webm".
  // Not a URL — callers sign on demand via SECURITY_AUDIT.md §4 endpoint
  // (to be built). Populated by the async pipeline (ENABLE_INNGEST_PIPELINE=1).
  audioPath     String?
  duration      Int?
  audioDuration Int?
  transcript    String?
  summary       String?
  mood          String?
  moodScore     Int?
  energy        Int?
  themes        String[]
  wins          String[]
  blockers      String[]
  rawExtraction Json?
  rawAnalysis   Json?
  // Valid status values (enforced by app code, not schema — we keep this a
  // String for flexibility across Postgres versions):
  //   QUEUED       — Inngest event dispatched, not yet running (async path)
  //   TRANSCRIBING — Whisper step in progress
  //   EXTRACTING   — Claude extraction step in progress
  //   PERSISTING   — DB transaction + memory/lifemap updates in progress
  //   COMPLETE     — all steps succeeded
  //   PARTIAL      — transcript exists but downstream step failed (recoverable)
  //   FAILED       — unrecoverable; errorMessage populated
  //   PENDING      — LEGACY: used by sync path until it's retired (Inngest PR 4)
  //   PROCESSING   — LEGACY: sync path intermediate state, same retirement
  status        String   @default("QUEUED")
  // User-safe error copy surfaced by onFailure handler when status=FAILED.
  errorMessage  String?
  // Narrows PARTIAL state — e.g. "extract-failed", "memory-update-failed",
  // "lifemap-update-failed". Always null unless status === "PARTIAL".
  partialReason String?
  // Cross-reference into Inngest's run dashboard for observability. Written
  // by processEntryFn's first step. Null for sync-path entries.
  inngestRunId  String?
  entryDate     DateTime @default(now())
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  tasks         Task[]
}

model Task {
  id           String    @id @default(cuid())
  userId       String
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  entryId      String?
  entry        Entry?    @relation(fields: [entryId], references: [id], onDelete: Cascade)
  text         String?
  title        String?
  description  String?
  status       String    @default("OPEN")
  priority     String    @default("MEDIUM")
  dueDate      DateTime?
  snoozedUntil DateTime?
  completedAt  DateTime?
  createdAt    DateTime  @default(now())
}

model Goal {
  id            String    @id @default(cuid())
  userId        String
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  title         String
  description   String?
  lifeArea      String    @default("PERSONAL")
  status        String    @default("ACTIVE")
  targetDate    DateTime?
  progress      Int       @default(0)
  progressNotes Json[]
  entryRefs     String[]
  createdAt     DateTime  @default(now())
}

model WeeklyReport {
  id              String   @id @default(cuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  weekStart       DateTime
  weekEnd         DateTime
  weekNumber      Int
  year            Int
  narrative       String?
  insightBullets  String[]
  moodArc         String?
  topThemes       String[]
  tasksOpened     Int      @default(0)
  tasksClosed     Int      @default(0)
  goalsProgressed String[]
  entryCount      Int      @default(0)
  // Valid status values (mirrors Entry.status vocabulary):
  //   QUEUED     — async path: Inngest event dispatched, not yet running
  //   GENERATING — Claude call in progress (sync path and async path)
  //   COMPLETE   — narrative + insightBullets + moodArc + topThemes populated
  //   FAILED     — unrecoverable; errorMessage populated
  status          String   @default("QUEUED")
  // User-safe error copy surfaced by onFailure handler when status=FAILED.
  errorMessage    String?
  // Cross-reference into Inngest's run dashboard; populated by
  // generateWeeklyReportFn's first step.
  inngestRunId    String?
  createdAt       DateTime @default(now())
}

model LifeMapArea {
  id              String    @id @default(cuid())
  userId          String
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  area            String    @default("")
  name            String?
  color           String?
  icon            String?
  sortOrder       Int       @default(0)
  score           Int       @default(5)
  summary         String?
  activeGoals     Int       @default(0)
  lastMentioned   DateTime?
  trend           String?   // "up", "down", "stable"
  weeklyDelta     Int?
  monthlyDelta    Int?
  mentionCount    Int       @default(0)
  topThemes       String[]
  insightSummary  String?
  historicalHigh  Int       @default(0)
  historicalLow   Int       @default(100)
  baselineScore   Int       @default(50)
  updatedAt       DateTime  @updatedAt
}

model UserMemory {
  id        String @id @default(cuid())
  userId    String @unique
  user      User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Compressed lifetime summary per area (AI-generated, updated incrementally).
  // Renamed 2026-04-19 to align with the canonical 6-area vocabulary
  // in `@acuity/shared::LIFE_AREAS`. wealth → finances, spirituality →
  // personal, relationship → relationships, growth → other.
  careerSummary        String?
  healthSummary        String?
  relationshipsSummary String?
  financesSummary      String?
  personalSummary      String?
  otherSummary         String?

  // Lifetime mention counts per area
  careerMentions       Int @default(0)
  healthMentions       Int @default(0)
  relationshipsMentions Int @default(0)
  financesMentions     Int @default(0)
  personalMentions     Int @default(0)
  otherMentions        Int @default(0)

  // Recurring patterns detected across all time
  recurringThemes Json[] // { area, theme, firstSeen, count, lastSeen }
  recurringPeople Json[] // { name, area, sentiment, mentionCount }
  recurringGoals  Json[] // { goal, area, firstMentioned, status, mentionCount }

  // Baseline scores (lifetime average, updated slowly)
  careerBaseline       Int @default(50)
  healthBaseline       Int @default(50)
  relationshipsBaseline Int @default(50)
  financesBaseline     Int @default(50)
  personalBaseline     Int @default(50)
  otherBaseline        Int @default(50)

  // Total entries processed
  totalEntries   Int       @default(0)
  firstEntryDate DateTime?
  lastCompressed DateTime?
  lastUpdated    DateTime  @updatedAt
}

// Long-form flagship AI output — Day 14 Life Audit, Day 90 Quarterly
// Audit, Day 365 Annual Audit. One row per audit per user per kind.
// IMPLEMENTATION_PLAN_PAYWALL.md §2.2.
model LifeAudit {
  id              String   @id @default(cuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  // Valid kinds: "TRIAL_DAY_14" | "QUARTERLY_90" | "ANNUAL_365".
  // Kept as String to avoid the Prisma-enum-vs-Postgres-version
  // awkwardness flagged elsewhere in the schema.
  kind            String
  // Window of entries the audit covered. For TRIAL_DAY_14 this is
  // the user's signup date through trialEndsAt.
  periodStart     DateTime
  periodEnd       DateTime
  entryCount      Int
  // The full audit narrative, including the closing "What comes next"
  // section. Renders as body copy on the audit view.
  narrative       String   @db.Text
  // The Month-2 transition paragraph, duplicated out of `narrative`
  // for easy re-render / copy-paste / future A/B testing. Matches
  // §4.1's "Continue it →" closing.
  closingLetter   String   @db.Text
  // { starting: [...], emerging: [...], fading: [...] } — theme arc
  // across the period.
  themesArc       Json
  // Per-area score change (UPPER_CASE area enum → delta). Optional;
  // the degraded fallback may skip this.
  lifeAreaDeltas  Json?
  // One-sentence emotional trajectory, e.g. "Started rough but landed
  // steady — the middle of week 2 was the turning point."
  moodArc         String?
  // Valid status: "QUEUED" | "GENERATING" | "COMPLETE" | "FAILED".
  status          String   @default("QUEUED")
  // User-safe error copy when status=FAILED.
  errorMessage    String?
  // Cross-reference into Inngest's run dashboard.
  inngestRunId    String?
  // True when the template-based fallback fired instead of a real
  // Claude generation. Filtered out of quality metrics. Users never
  // know they got the fallback — voice is matched to the few-shot.
  // IMPLEMENTATION_PLAN_PAYWALL §7.3.
  degraded        Boolean  @default(false)
  createdAt       DateTime @default(now())

  @@index([userId, createdAt])
  @@index([userId, kind])
}

model Waitlist {
  id                String   @id @default(cuid())
  email             String   @unique
  name              String?
  source            String?
  createdAt         DateTime @default(now())
  emailSequenceStep Int      @default(0)
  unsubscribed      Boolean  @default(false)
}

// ─── Content Factory ──────────────────────────────────────────────────────────

model ContentBriefing {
  id          String         @id @default(cuid())
  date        DateTime       @unique
  redditTop   Json
  twitterTop  Json
  trendsData  Json
  ga4Winners  Json
  generatedAt DateTime       @default(now())
  pieces      ContentPiece[]
}

model ContentPiece {
  id               String            @id @default(cuid())
  type             ContentType
  title            String
  body             String            @db.Text
  hook             String
  cta              String
  targetKeyword    String?
  predictedScore   Float
  sourceBriefingId String?
  sourceBriefing   ContentBriefing?  @relation(fields: [sourceBriefingId], references: [id])
  status           ContentStatus     @default(PENDING_REVIEW)
  reviewedAt       DateTime?
  reviewedBy       String?
  editNotes        String?
  finalBody        String?           @db.Text
  distributedAt    DateTime?
  distributedUrl   String?
  metrics          Json?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
}

model ClaudeCallLog {
  id           String   @id @default(cuid())
  purpose      String
  model        String
  tokensIn     Int
  tokensOut    Int
  costCents    Int
  durationMs   Int
  success      Boolean
  errorMessage String?
  createdAt    DateTime @default(now())
}

enum ContentType {
  BLOG
  TWITTER
  TIKTOK
  AD_COPY
  EMAIL
}

enum ContentStatus {
  PENDING_REVIEW
  APPROVED
  REJECTED
  EDITED
  DISTRIBUTED
}
