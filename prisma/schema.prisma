generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model User {
  id                     String       @id @default(cuid())
  email                  String       @unique
  emailVerified          DateTime?
  // bcrypt hash for email/password accounts. Null for OAuth-only users
  // (Google sign-ins that never set a password). A user with a Google
  // Account row AND a passwordHash has linked both auth methods.
  passwordHash           String?
  // Random token issued during the forgot-password flow. Cleared on
  // use or on natural expiry. @unique so the lookup in the reset
  // handler is indexed without a composite.
  resetToken             String?      @unique
  resetTokenExpires      DateTime?
  name                   String?
  image                  String?
  avatarUrl              String?
  stripeCustomerId       String?
  stripeSubscriptionId   String?
  stripeCurrentPeriodEnd DateTime?
  subscriptionStatus     String       @default("TRIAL")
  trialEndsAt            DateTime?
  timezone               String       @default("America/Chicago")
  // DEPRECATED: superseded by notificationTime + notificationDays +
  // notificationsEnabled (added 2026-04-20 alongside the onboarding
  // notifications step). Left in place because a fresh schema diff
  // without it would drop column data from any env where it was set
  // manually; read paths should prefer `notificationTime`.
  reminderTime           String       @default("21:00")
  pushToken              String?
  // HH:MM in the user's timezone. Combined with `notificationDays`
  // to schedule the local reminder (mobile via expo-notifications)
  // or the daily email (web, future).
  notificationTime       String       @default("21:00")
  // 0=Sunday..6=Saturday. Days the reminder fires. Empty array = no
  // days active (same effect as notificationsEnabled=false, but
  // preserves the preference the user last picked).
  notificationDays       Int[]        @default([0, 1, 2, 3, 4, 5, 6])
  notificationsEnabled   Boolean      @default(false)
  // Granted manually via direct DB update (UPDATE "User" SET "isAdmin" = true WHERE email = '...').
  // Not self-service. Gates /admin/dashboard + /api/admin/*.
  isAdmin                Boolean      @default(false)
  // Color-scheme preference. Null (default) → follow system / localStorage
  // whatever next-themes picks up. Set to "light" or "dark" when the
  // user explicitly picks via the toggle; we persist to the DB so the
  // preference survives across devices without relying on localStorage.
  theme                  String?
  // Streak tracking — incremented by the Inngest process-entry pipeline
  // after a successful recording persists. Day boundaries evaluated in
  // the user's `timezone` via date-fns-tz (same-day = no change,
  // next-calendar-day = +1, gap of 2+ days = reset to 1). Full rules in
  // apps/web/src/lib/streak.ts.
  currentStreak          Int          @default(0)
  longestStreak          Int          @default(0)
  lastSessionDate        DateTime?
  // Highest milestone we've celebrated for this user (7, 30, 100). NULL
  // means no milestone fired yet. Set once and monotonically increases —
  // a user who drops from 100 back to 0 and climbs again gets a new
  // milestone toast only if they exceed lastMilestone.
  lastStreakMilestone    Int?
  // Cookie/analytics consent record — stored as JSON so we can evolve
  // the categories without a migration. Shape: { version:1, acceptedAt,
  // analytics:boolean, marketing:boolean }. Null = user has never seen
  // the banner or logged-in-from-another-device. Mirror of the
  // localStorage record on the client.
  cookieConsent          Json?
  createdAt              DateTime     @default(now())
  // Last time the user loaded a page / opened the app. Updated
  // opportunistically from /api/user/me; not strongly durable.
  // Drives the onboarding smart-skip ("abandoned 30+ days ago →
  // silently mark complete") and future engagement signals.
  lastSeenAt             DateTime?
  // Unique short code (8 char, no ambiguous chars) the user shares
  // via their /?ref= link. Generated lazily on first /account view
  // or at signup — see lib/referrals.ts::generateReferralCode.
  referralCode           String?      @unique
  // ID of the user who referred them (if they signed up via a ?ref=
  // link). Null for self-directed signups. SetNull on referrer
  // delete so we don't lose the downstream graph.
  referredById           String?
  referredBy             User?        @relation("Referrals", fields: [referredById], references: [id], onDelete: SetNull)
  referrals              User[]       @relation("Referrals")
  // Subscription email toggles (W2). Default both on; unsubscribe
  // link in any digest footer flips the relevant boolean via a
  // token-based endpoint.
  weeklyEmailEnabled     Boolean      @default(true)
  monthlyEmailEnabled    Boolean      @default(true)
  // Dedup keys for the weekly/monthly digest Inngest crons. Scan
  // window uses (now - last*At < threshold) so a retried cron or
  // overlap doesn't double-send. Null = never sent.
  lastWeeklyDigestAt     DateTime?
  lastMonthlyDigestAt    DateTime?
  accounts               Account[]
  sessions               Session[]
  entries                Entry[]
  tasks                  Task[]
  taskGroups             TaskGroup[]
  goals                  Goal[]
  weeklyReports          WeeklyReport[]
  lifemapAreas           LifeMapArea[]
  memory                 UserMemory?
  lifeAudits             LifeAudit[]
  onboarding             UserOnboarding?
  demographics           UserDemographics?
  userInsights           UserInsight[]
  themes                 Theme[]
  referralConversionsAsReferrer ReferralConversion[] @relation("ReferrerConversions")
  referralConversionsAsReferred ReferralConversion[] @relation("ReferredConversions")
  dataExports            DataExport[]
  healthSnapshots        HealthSnapshot[]
  // Apple Health connection state. True once the user accepts the
  // iOS HealthKit permission prompt; cleared when they revoke in
  // Settings or toggle off from Profile → Connected apps. Null on
  // Android / never-connected iOS accounts.
  healthConnectedAt      DateTime?
  stateOfMeReports       StateOfMeReport[]
  lifeDimensions         UserLifeDimension[]
  calendarConnections    CalendarConnection[]
  // Preset template the user picked for their Life Matrix labels.
  // "DEFAULT" | "STUDENT" | "PARENT" | "CUSTOM" | null. Null means
  // the user has never customized — render the canonical labels.
  lifeDimensionPreset    String?
  // Accrued referral reward days for users who AREN'T on trial when
  // their conversion fires (paid / past-due / free). Applied at the
  // next subscription renewal — TODO: hook this into the renewal
  // handler. For TRIAL referrers we extend `trialEndsAt` directly
  // and this column stays at 0. Capped indirectly via
  // REFERRAL_ANNUAL_CAP in lib/referrals.ts.
  referralRewardDays     Int          @default(0)

  @@index([createdAt])
}

// Tombstone for deleted accounts — closes the trial-reset exploit
// documented as pentest T-07 in docs/PENTEST_RESULTS.md. On account
// deletion we write this row BEFORE cascading the User delete so a
// subsequent signup with the same email can be looked up and the
// trial policy adjusted.
//
// Retention policy (see apps/web/src/lib/bootstrap-user.ts::issueTrial):
//   - Seen within 90 days → 3-day re-trial
//   - Seen >90 days ago   → fresh 14-day trial
//   - Never seen          → fresh 14-day trial (first-timer)
//
// No FK to User (the point is that the User is gone). Email is the
// only stable identifier.
model DeletedUser {
  email                String   @id
  deletedAt            DateTime @default(now())
  originalCreatedAt    DateTime
  originalTrialEndedAt DateTime?
}

// 8-step post-signup onboarding flow. One row per user; survives
// account deletion via cascade. Completed users are identified by
// `completedAt != null` — the dashboard uses this to decide whether
// to redirect new users into the flow. See apps/web/src/app/onboarding/
// for the UI scaffold.
model UserOnboarding {
  id                     String    @id @default(cuid())
  userId                 String    @unique
  user                   User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  // Last step the user reached. 1-indexed. When completedAt is set
  // this also carries the final step number for auditing.
  currentStep            Int       @default(1)
  // Null until the user finishes step 8 (or hits Skip on the last
  // skippable step). Non-null means "don't redirect into onboarding
  // anymore".
  completedAt            DateTime?
  // Step 5 — mood baseline (one of GREAT|GOOD|NEUTRAL|LOW|ROUGH).
  // Seeds the Life Matrix starting scores so day-1 insights aren't
  // drawing against a zero baseline.
  moodBaseline           String?
  // Step 6 — user's ranked importance for the 6 canonical life areas.
  // Stored as Json: { CAREER: 3, HEALTH: 5, RELATIONSHIPS: 4, ... }
  // where higher numbers = higher importance (1-5 scale).
  lifeAreaPriorities     Json?
  // Step 2 — where they found Acuity. Free-text, short list. Drives
  // PostHog attribution (signupSource property on trial_started).
  referralSource         String?
  // Step 7 — expected weekly cadence. "DAILY" | "WEEKDAYS" | "WEEKLY"
  // | "UNSURE". Informs the post-trial email copy + reminder default.
  expectedUsageFrequency String?
  // Step 4 — did the user grant microphone permission during the
  // walkthrough? False doesn't block completion (they can grant later
  // from Settings) but we track it so the dashboard can nudge.
  microphoneGranted      Boolean   @default(false)
  // 14-day "Getting to know Acuity" discovery checklist. JSON shape:
  //   { dismissedAt: ISO?,
  //     items: { day1: ISO|null, day2: ISO|null, ..., day14: ISO|null } }
  // Null = user hasn't interacted yet; auto-hydrated on first render.
  // See apps/web/src/lib/progression.ts for the item definitions +
  // auto-complete heuristics (Day 1 = any Entry exists, Day 7 = any
  // WeeklyReport, Day 14 = any LifeAudit). Other days require manual
  // tap because we don't have the signal to auto-detect.
  progressionChecklist   Json?
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt
}

model Entry {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  // DEPRECATED: use audioPath. Will remove in Inngest PR 4 once the sync
  // path is retired. Sync path writes a signed URL here; async path leaves
  // this null and writes the object path to audioPath instead.
  audioUrl      String?
  // Supabase Storage object path, e.g. "voice-entries/${userId}/${entryId}.webm".
  // Not a URL — callers sign on demand via SECURITY_AUDIT.md §4 endpoint
  // (to be built). Populated by the async pipeline (ENABLE_INNGEST_PIPELINE=1).
  audioPath     String?
  duration      Int?
  audioDuration Int?
  transcript    String?
  summary       String?
  mood          String?
  moodScore     Int?
  energy        Int?
  themes        String[]
  wins          String[]
  blockers      String[]
  rawExtraction Json?
  rawAnalysis   Json?
  // OpenAI text-embedding-3-small output (1536 dims) on
  // `summary + transcript`. Populated by the extraction pipeline
  // post-Claude and by the backfill script. Null on legacy rows
  // until backfill runs. Cosine similarity computed in app memory —
  // no pgvector index. At 10k entries × 1536 dims × 4 bytes =
  // ~60MB max per-user read, well under memory limits; if we blow
  // past that we promote to pgvector.
  embedding     Float[]
  // Valid status values (enforced by app code, not schema — we keep this a
  // String for flexibility across Postgres versions):
  //   QUEUED       — Inngest event dispatched, not yet running (async path)
  //   TRANSCRIBING — Whisper step in progress
  //   EXTRACTING   — Claude extraction step in progress
  //   PERSISTING   — DB transaction + memory/lifemap updates in progress
  //   COMPLETE     — all steps succeeded
  //   PARTIAL      — transcript exists but downstream step failed (recoverable)
  //   FAILED       — unrecoverable; errorMessage populated
  //   PENDING      — LEGACY: used by sync path until it's retired (Inngest PR 4)
  //   PROCESSING   — LEGACY: sync path intermediate state, same retirement
  status        String   @default("QUEUED")
  // User-safe error copy surfaced by onFailure handler when status=FAILED.
  errorMessage  String?
  // Narrows PARTIAL state — e.g. "extract-failed", "memory-update-failed",
  // "lifemap-update-failed". Always null unless status === "PARTIAL".
  partialReason String?
  // Cross-reference into Inngest's run dashboard for observability. Written
  // by processEntryFn's first step. Null for sync-path entries.
  inngestRunId  String?
  entryDate     DateTime @default(now())
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  // Optional goal this entry is specifically "about" — set when the user
  // taps "Record about this goal" from a goal card/detail. When present,
  // the extraction pipeline splices the goal's title + description into
  // the Claude prompt so the AI treats the entry as goal-contextualized.
  // Null for standard recordings.
  goalId        String?
  goal          Goal?    @relation(fields: [goalId], references: [id], onDelete: SetNull)
  // Optional life-dimension context. Set when the user opened the
  // recorder from a dimension detail screen via "Record about this".
  // Stored as the lowercase dimension key from DEFAULT_LIFE_AREAS
  // ("career" / "health" / "relationships" / "finances" / "personal" /
  // "other") so the extraction pipeline can splice the human-readable
  // area name into the Claude prompt without a DB join. Nullable.
  dimensionContext String?
  tasks         Task[]
  themeMentions ThemeMention[]

  @@index([userId, createdAt])
  @@index([goalId])
}

model TaskGroup {
  id             String   @id @default(cuid())
  userId         String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name           String
  icon           String
  color          String
  order          Int      @default(0)
  isDefault      Boolean  @default(false)
  // True when the row was seeded automatically on first-task-fetch for
  // this user (vs. a group the user explicitly created from the
  // Settings UI). Lets future UX distinguish "we guessed this for you"
  // groups from "you made this" groups in the onboarding tooltip.
  isAIGenerated  Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  tasks          Task[]

  @@unique([userId, name])
  @@index([userId, order])
}

model Task {
  id           String     @id @default(cuid())
  userId       String
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  entryId      String?
  entry        Entry?     @relation(fields: [entryId], references: [id], onDelete: Cascade)
  // Optional group anchor. Set by the extraction pipeline's AI
  // classification step, or manually from the task-list "Move to…"
  // action. onDelete: SetNull so deleting a group turns its tasks
  // into ungrouped rows rather than cascading them away.
  groupId      String?
  group        TaskGroup? @relation(fields: [groupId], references: [id], onDelete: SetNull)
  // Optional goal anchor — a task is a leaf-level contributor in the
  // Goal Tree. null means the task is not attached to any goal. Set
  // by the suggestion-accept flow or manually from the goal detail.
  goalId       String?
  goal         Goal?     @relation(fields: [goalId], references: [id], onDelete: SetNull)
  text         String?
  title        String?
  description  String?
  status       String    @default("OPEN")
  priority     String    @default("MEDIUM")
  dueDate      DateTime?
  snoozedUntil DateTime?
  completedAt  DateTime?
  createdAt    DateTime  @default(now())

  @@index([goalId])
}

model Goal {
  id              String    @id @default(cuid())
  userId          String
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  title           String
  description     String?
  lifeArea        String    @default("PERSONAL")
  // Valid values (enforced by app code, kept as String for cross-version
  // Postgres compatibility):
  //   NOT_STARTED | IN_PROGRESS | ON_HOLD | COMPLETE | ARCHIVED
  //
  // Status semantics:
  //   NOT_STARTED — extracted from an entry, user hasn't engaged yet
  //   IN_PROGRESS — actively working
  //   ON_HOLD     — paused intentionally, still in the main list
  //   COMPLETE    — shipped
  //   ARCHIVED    — user dismissed; hidden from main list + recommendations
  //                 (W5 2026-04-21 — split from ON_HOLD because users kept
  //                 conflating "paused for now" with "hide this from me")
  //
  // Migration history:
  //   2026-04-20: ACTIVE→IN_PROGRESS, COMPLETED→COMPLETE,
  //               PAUSED→ON_HOLD, ABANDONED→ON_HOLD.
  //   2026-04-22: ARCHIVED added as a distinct 5th value. Pre-existing
  //               ON_HOLD rows stay ON_HOLD (can't safely promote
  //               without user intent); going forward Archive action
  //               writes ARCHIVED.
  //
  // Default on extraction-created goals stays NOT_STARTED; users flip
  // to IN_PROGRESS from the detail view when they actually start.
  status          String    @default("NOT_STARTED")
  targetDate      DateTime?
  progress        Int       @default(0)
  progressNotes   Json[]
  entryRefs       String[]
  // Free-form user-authored notes (detail view textarea). Keeps the
  // AI-generated `description` separate from the reflection layer the
  // user adds after creation.
  notes           String?
  // Last time any entry mentioned this goal (by title match during
  // extraction). Drives the "stale 7+ days" tier-1 recommended activity
  // surface so the user can refresh commitment.
  lastMentionedAt DateTime?
  // True once the user has edited title/description/status/progress/notes
  // from the detail view. Extraction pipeline respects this — won't
  // overwrite a user-edited goal with a later re-extraction.
  editedByUser    Boolean   @default(false)
  // Self-referential parent for the Goal Progression Tree. null = root.
  // App-layer enforces max depth = 4 and prevents cycles; a Prisma
  // CHECK constraint isn't portable across Postgres versions and a
  // runtime guard in the API covers the same cases.
  parentGoalId    String?
  parent          Goal?     @relation("GoalTree", fields: [parentGoalId], references: [id], onDelete: SetNull)
  children        Goal[]    @relation("GoalTree")
  // Materialized path for subtree queries: "/rootId/midId/" style.
  // Recomputed on insert + on reparent. Null for legacy rows; the
  // tree API tolerates null and treats them as root-level.
  treePath        String?
  // 0 = root. 1..4 = descendants. Enforced at the API layer.
  depth           Int       @default(0)
  createdAt       DateTime  @default(now())
  tasks           Task[]
  entries         Entry[]
  suggestions     GoalSuggestion[]

  @@index([userId, status])
  @@index([parentGoalId])
}

model WeeklyReport {
  id              String   @id @default(cuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  weekStart       DateTime
  weekEnd         DateTime
  weekNumber      Int
  year            Int
  narrative       String?
  insightBullets  String[]
  moodArc         String?
  topThemes       String[]
  tasksOpened     Int      @default(0)
  tasksClosed     Int      @default(0)
  goalsProgressed String[]
  entryCount      Int      @default(0)
  // Valid status values (mirrors Entry.status vocabulary):
  //   QUEUED     — async path: Inngest event dispatched, not yet running
  //   GENERATING — Claude call in progress (sync path and async path)
  //   COMPLETE   — narrative + insightBullets + moodArc + topThemes populated
  //   FAILED     — unrecoverable; errorMessage populated
  status          String   @default("QUEUED")
  // User-safe error copy surfaced by onFailure handler when status=FAILED.
  errorMessage    String?
  // Cross-reference into Inngest's run dashboard; populated by
  // generateWeeklyReportFn's first step.
  inngestRunId    String?
  // Public share link. When non-null, /shared/weekly/[publicShareId]
  // renders a read-only view (no auth). Unique across all users so
  // the URL can't be guessed from a user id + week offset.
  publicShareId         String?  @unique
  publicShareExpiresAt  DateTime?
  publicShareViewCount  Int      @default(0)
  createdAt       DateTime @default(now())

  @@index([userId, createdAt])
}

model LifeMapArea {
  id              String    @id @default(cuid())
  userId          String
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  area            String    @default("")
  name            String?
  color           String?
  icon            String?
  sortOrder       Int       @default(0)
  score           Int       @default(5)
  summary         String?
  activeGoals     Int       @default(0)
  lastMentioned   DateTime?
  trend           String?   // "up", "down", "stable"
  weeklyDelta     Int?
  monthlyDelta    Int?
  mentionCount    Int       @default(0)
  topThemes       String[]
  insightSummary  String?
  historicalHigh  Int       @default(0)
  historicalLow   Int       @default(100)
  baselineScore   Int       @default(50)
  updatedAt       DateTime  @updatedAt
}

model UserMemory {
  id        String @id @default(cuid())
  userId    String @unique
  user      User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Compressed lifetime summary per area (AI-generated, updated incrementally).
  // Renamed 2026-04-19 to align with the canonical 6-area vocabulary
  // in `@acuity/shared::LIFE_AREAS`. wealth → finances, spirituality →
  // personal, relationship → relationships, growth → other.
  careerSummary        String?
  healthSummary        String?
  relationshipsSummary String?
  financesSummary      String?
  personalSummary      String?
  otherSummary         String?

  // Lifetime mention counts per area
  careerMentions       Int @default(0)
  healthMentions       Int @default(0)
  relationshipsMentions Int @default(0)
  financesMentions     Int @default(0)
  personalMentions     Int @default(0)
  otherMentions        Int @default(0)

  // Recurring patterns detected across all time
  recurringThemes Json[] // { area, theme, firstSeen, count, lastSeen }
  recurringPeople Json[] // { name, area, sentiment, mentionCount }
  recurringGoals  Json[] // { goal, area, firstMentioned, status, mentionCount }

  // Baseline scores (lifetime average, updated slowly)
  careerBaseline       Int @default(50)
  healthBaseline       Int @default(50)
  relationshipsBaseline Int @default(50)
  financesBaseline     Int @default(50)
  personalBaseline     Int @default(50)
  otherBaseline        Int @default(50)

  // Total entries processed
  totalEntries   Int       @default(0)
  firstEntryDate DateTime?
  lastCompressed DateTime?
  lastUpdated    DateTime  @updatedAt
}

// Long-form flagship AI output — Day 14 Life Audit, Day 90 Quarterly
// Audit, Day 365 Annual Audit. One row per audit per user per kind.
// IMPLEMENTATION_PLAN_PAYWALL.md §2.2.
model LifeAudit {
  id              String   @id @default(cuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  // Valid kinds: "TRIAL_DAY_14" | "QUARTERLY_90" | "ANNUAL_365".
  // Kept as String to avoid the Prisma-enum-vs-Postgres-version
  // awkwardness flagged elsewhere in the schema.
  kind            String
  // Window of entries the audit covered. For TRIAL_DAY_14 this is
  // the user's signup date through trialEndsAt.
  periodStart     DateTime
  periodEnd       DateTime
  entryCount      Int
  // The full audit narrative, including the closing "What comes next"
  // section. Renders as body copy on the audit view.
  narrative       String   @db.Text
  // The Month-2 transition paragraph, duplicated out of `narrative`
  // for easy re-render / copy-paste / future A/B testing. Matches
  // §4.1's "Continue it →" closing.
  closingLetter   String   @db.Text
  // { starting: [...], emerging: [...], fading: [...] } — theme arc
  // across the period.
  themesArc       Json
  // Per-area score change (UPPER_CASE area enum → delta). Optional;
  // the degraded fallback may skip this.
  lifeAreaDeltas  Json?
  // One-sentence emotional trajectory, e.g. "Started rough but landed
  // steady — the middle of week 2 was the turning point."
  moodArc         String?
  // Valid status: "QUEUED" | "GENERATING" | "COMPLETE" | "FAILED".
  status          String   @default("QUEUED")
  // User-safe error copy when status=FAILED.
  errorMessage    String?
  // Cross-reference into Inngest's run dashboard.
  inngestRunId    String?
  // True when the template-based fallback fired instead of a real
  // Claude generation. Filtered out of quality metrics. Users never
  // know they got the fallback — voice is matched to the few-shot.
  // IMPLEMENTATION_PLAN_PAYWALL §7.3.
  degraded        Boolean  @default(false)
  createdAt       DateTime @default(now())

  @@index([userId, createdAt])
  @@index([userId, kind])
}

model Waitlist {
  id                String   @id @default(cuid())
  email             String   @unique
  name              String?
  source            String?
  createdAt         DateTime @default(now())
  emailSequenceStep Int      @default(0)
  unsubscribed      Boolean  @default(false)
}

// ─── Content Factory ──────────────────────────────────────────────────────────

model ContentBriefing {
  id          String         @id @default(cuid())
  date        DateTime       @unique
  redditTop   Json
  twitterTop  Json
  trendsData  Json
  ga4Winners  Json
  generatedAt DateTime       @default(now())
  pieces      ContentPiece[]
}

model ContentPiece {
  id               String            @id @default(cuid())
  type             ContentType
  title            String
  body             String            @db.Text
  hook             String
  cta              String
  targetKeyword    String?
  predictedScore   Float
  sourceBriefingId String?
  sourceBriefing   ContentBriefing?  @relation(fields: [sourceBriefingId], references: [id])
  status           ContentStatus     @default(PENDING_REVIEW)
  reviewedAt       DateTime?
  reviewedBy       String?
  editNotes        String?
  finalBody        String?           @db.Text
  distributedAt    DateTime?
  distributedUrl   String?
  slug             String?           @unique
  metrics          Json?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  @@index([type, status, createdAt])
}

model ClaudeCallLog {
  id           String   @id @default(cuid())
  purpose      String
  model        String
  tokensIn     Int
  tokensOut    Int
  costCents    Int
  durationMs   Int
  success      Boolean
  errorMessage String?
  createdAt    DateTime @default(now())
}

enum ContentType {
  BLOG
  TWITTER
  TIKTOK
  AD_COPY
  EMAIL
  REDDIT_DRAFT
}

enum ContentStatus {
  PENDING_REVIEW
  APPROVED
  REJECTED
  EDITED
  DISTRIBUTED
}

// ─── Generation Job Tracking ─────────────────────────────────────────────────

model GenerationJob {
  id            String    @id @default(cuid())
  status        JobStatus @default(QUEUED)
  currentStep   Int       @default(0)
  totalSteps    Int       @default(12)
  stepLabel     String    @default("Queued…")
  errorMessage  String?
  piecesCreated Int       @default(0)
  startedAt     DateTime  @default(now())
  completedAt   DateTime?
  triggeredBy   String?
}

enum JobStatus {
  QUEUED
  RUNNING
  SUCCESS
  FAILED
}

// Optional demographic metadata collected during onboarding step 3.
// All fields nullable — every field ships with a "Prefer not to say"
// option so the user can proceed without sharing anything. Used for
// analytics segmentation and tailored insight copy, not for gating.
model UserDemographics {
  id             String   @id @default(cuid())
  userId         String   @unique
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  // One of "18-24" | "25-34" | "35-44" | "45-54" | "55+"
  ageRange       String?
  // One of "Male" | "Female" | "Non-binary" | "Prefer not to say"
  gender         String?
  // ISO 3166-1 alpha-2 (e.g. "US", "GB"). IP-suggested default on the
  // client, user can override.
  country        String?
  // Multi-select: any of "Career" | "Relationships" | "Mental health"
  // | "Productivity" | "Curiosity" | "Other"
  primaryReasons String[]
  // One of "Student" | "Early career" | "Established career" | "Parent"
  // | "Retired" | "In transition" | "Prefer not to say"
  lifeStage      String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

// Weekly snapshot of each user's LifeMapArea scores. Written by the
// snapshot-lifemap-history Inngest cron (weekly, Sunday 00:05 UTC).
// Drives the Current/Trend toggle on the Insights radar — rendering the
// "4 weeks ago" overlay polygon requires one snapshot per area per week.
// No backfill; history starts the week this model ships.
model LifeMapAreaHistory {
  id         String   @id @default(cuid())
  userId     String
  // Which area (CAREER|HEALTH|...) — same vocabulary as LifeMapArea.area.
  area       String
  score      Int
  // ISO date of the Sunday that begins the snapshot week (UTC midnight).
  // Unique per (userId, area, weekStart) so re-runs are idempotent.
  weekStart  DateTime
  createdAt  DateTime @default(now())

  @@unique([userId, area, weekStart])
  @@index([userId, weekStart])
}

// Auto-flagged observations — surfaces 1–3 at the top of Insights.
// Generated by the weekly Inngest cron `compute-user-insights`.
model UserInsight {
  id              String    @id @default(cuid())
  userId          String
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  // Short user-facing copy, e.g. "Your Health score dropped 2 points
  // this week" or "You mentioned stress 3x more than last week".
  observationText String
  // "POSITIVE" | "NEUTRAL" | "CONCERNING" — drives the left-border tint
  // and icon on the Insight card.
  severity        String
  // Area key if the observation is tied to a LifeMapArea row. Kept as
  // a plain String (not FK) because observations can reference deleted
  // or historical areas and shouldn't cascade-break.
  linkedAreaId    String?
  // Which model generated this observation. "heuristic" for the
  // deterministic pre-Claude output, "claude-opus-4-7" or similar
  // for the Claude-generated flagship path. Lets us eval model
  // quality against dismissal rates later.
  generationModel String    @default("heuristic")
  dismissedAt     DateTime?
  createdAt       DateTime  @default(now())

  @@index([userId, createdAt])
  @@index([userId, dismissedAt])
}

// ─── Theme Evolution Map ─────────────────────────────────────────────────────
//
// Relational theme model laid down alongside the legacy Entry.themes
// String[] column (which still feeds weekly reports, life audits, and
// the user-insight cron). Powers the force-directed Theme Map graph
// without paying a full-table scan on every read.
//
// One Theme row per distinct normalized name per user — see
// apps/web/src/lib/themes.ts::normalizeThemeName for the canonicalization
// rules (lowercase + trim + whitespace collapse + conservative plural
// stemming). One ThemeMention per (theme, entry) pair; sentiment is
// captured per-theme by the extraction prompt update that landed
// alongside this model.
model Theme {
  id        String         @id @default(cuid())
  userId    String
  user      User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  name      String
  createdAt DateTime       @default(now())
  mentions  ThemeMention[]

  @@unique([userId, name])
  @@index([userId])
}

model ThemeMention {
  id        String   @id @default(cuid())
  themeId   String
  theme     Theme    @relation(fields: [themeId], references: [id], onDelete: Cascade)
  entryId   String
  entry     Entry    @relation(fields: [entryId], references: [id], onDelete: Cascade)
  // "POSITIVE" | "NEUTRAL" | "NEGATIVE" — string for cross-Postgres
  // compatibility, same pattern as Entry.status.
  sentiment String   @default("NEUTRAL")
  // Denormalized from Entry.createdAt so time-window queries on the
  // Theme Map don't have to join Entry.
  createdAt DateTime @default(now())

  @@unique([themeId, entryId])
  @@index([themeId, createdAt])
  @@index([entryId])
}

// ─── Goal Progression Tree ───────────────────────────────────────────────────
//
// Extraction-pipeline-proposed sub-goals the user can accept, dismiss,
// or edit-then-accept. parentGoalId may be null for top-level
// suggestions (rare — the current extraction hook only emits
// suggestions when it matches an existing goal, so parentGoalId is
// usually non-null). Nullable to leave room for future flows.
//
// sourceEntryId keeps provenance so the suggestion UI can show "from
// your Oct 15 entry" with a deep link.
model GoalSuggestion {
  id            String    @id @default(cuid())
  userId        String
  // null when the suggestion is free-floating. Non-null anchors it to
  // a specific parent goal. onDelete: SetNull so deleting a parent goal
  // doesn't lose the suggestion — it becomes a top-level proposal.
  parentGoalId  String?
  parentGoal    Goal?     @relation(fields: [parentGoalId], references: [id], onDelete: SetNull)
  suggestedText String
  sourceEntryId String?
  // "PENDING" | "ACCEPTED" | "DISMISSED" — String for cross-version
  // compatibility (same pattern as other status columns).
  status        String    @default("PENDING")
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([userId, status])
  @@index([parentGoalId])
}

// Idempotency record for Stripe webhook deliveries. Stripe retries
// at-least-once semantics — same event.id can arrive multiple times.
// We short-circuit on id collision so repeated deliveries don't
// double-write subscription state.
model StripeEvent {
  id          String   @id  // stripe event.id, e.g. "evt_1TL…"
  type        String
  processedAt DateTime @default(now())
}

// One row per trial→paid conversion that had a referrer. Reward
// fulfillment is a TODO (Jim picks the reward) — this table just
// records the event so accounting stays clean when we wire rewards.
// Unique per (referrer, referred) so repeated conversions from the
// same user don't double-count.
model ReferralConversion {
  id              String   @id @default(cuid())
  referrerId      String
  referrer        User     @relation("ReferrerConversions", fields: [referrerId], references: [id], onDelete: Cascade)
  referredUserId  String
  referredUser    User     @relation("ReferredConversions", fields: [referredUserId], references: [id], onDelete: Cascade)
  convertedAt     DateTime @default(now())

  @@unique([referrerId, referredUserId])
  @@index([referrerId])
}

// Async user-data export request (W3 GDPR). One row per request;
// signed-URL expires after 24h; next request blocked by 7-day
// server-side throttle — see apps/web/src/app/api/user/export route.
model DataExport {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  // "PENDING" | "PROCESSING" | "READY" | "FAILED" | "EXPIRED"
  status        String   @default("PENDING")
  // Signed Supabase URL to the zip in the user-exports bucket. Null
  // until status=READY.
  downloadUrl   String?
  // After this instant the download link stops working. We still
  // retain the row for audit even after the object is deleted.
  expiresAt     DateTime?
  errorMessage  String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([userId, createdAt])
}

// ─── Admin Dashboard ─────────────────────────────────────────────────────────

// Daily snapshot of key business metrics, computed by a 2 AM Inngest cron.
// Lets the admin dashboard show historical trends without recomputing from
// raw User/Entry tables for dates older than 7 days.
model DashboardSnapshot {
  id             String   @id @default(cuid())
  date           DateTime @unique
  mrr            Int      // cents
  totalSubs      Int
  dau            Int
  wau            Int
  mau            Int
  signupsThisDay Int
  aiCostCents    Int
  metadata       Json     // flexible bucket for other metrics
  createdAt      DateTime @default(now())
}

// Manual weekly ad spend input per campaign. Meta Marketing API automation
// is a future enhancement — for now the operator enters spend from the
// Meta Ads Manager each week.
model MetaSpend {
  id         String   @id @default(cuid())
  weekStart  DateTime
  campaign   String   // therapy | sleep | founders | decoded | weekly-report | main
  spendCents Int
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([weekStart, campaign])
}

// System health issues detected by the 6-hourly red flag scanner.
// Displayed on the Red Flags tab; operator can dismiss or resolve.
model RedFlag {
  id              String       @id @default(cuid())
  severity        FlagSeverity
  category        String       // webhook | inngest | payment | trial | email | ai_budget
  title           String
  description     String
  affectedUserIds String[]
  resolved        Boolean      @default(false)
  resolvedAt      DateTime?
  createdAt       DateTime     @default(now())
}

enum FlagSeverity {
  CRITICAL
  WARNING
  INFO
}

// Daily HealthKit snapshot. One row per (userId, date). Written by
// the mobile app's Background Fetch worker which pulls yesterday's
// HealthKit aggregates each morning. All metrics nullable because
// HealthKit data availability varies by device + user permissions.
// Insights layer reads this to compute mood/sleep correlations.
model HealthSnapshot {
  id             String   @id @default(cuid())
  userId         String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  // Local calendar date the metrics belong to (YYYY-MM-DD in the
  // user's timezone). Stored as DateTime with time=00:00:00 UTC so
  // query ranges stay simple; the timezone context lives on User.
  date           DateTime
  sleepHours     Float?
  steps          Int?
  avgHRV         Float?   // milliseconds, HealthKit's HKQuantityTypeIdentifierHeartRateVariabilitySDNN
  activeMinutes  Int?     // Apple's "Exercise minutes" ring equivalent
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([userId, date])
  @@index([userId, date])
}

// Per-user display overrides for the 6 canonical life areas. The
// extraction pipeline + UserMemory + Goal.lifeArea + LifeMapArea.area
// still speak the canonical LifeArea vocabulary (CAREER|HEALTH|...);
// this table is purely a label/color/visibility override for the
// Life Matrix UI. That keeps the data model coherent across users
// while letting each person phrase their dimensions in their own
// vocabulary (e.g. "Work & school" for a student, "Family & partner"
// for a parent). When a user has zero rows here, the UI falls back
// to the canonical DEFAULT_LIFE_AREAS.
//
// Promotion path to truly configurable dimensions:
//   - Add a `key` column that replaces `area` (free-form slug).
//   - Migrate extraction prompt to emit keys dynamically.
//   - Widen UserMemory to a relational per-dimension row.
// Out of scope for beta.
model UserLifeDimension {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  // One of the canonical LIFE_AREAS values (CAREER|HEALTH|...).
  area        String
  // User-chosen display label. "Work & school" instead of "Career", etc.
  label       String
  description String?
  color       String?
  icon        String?
  sortOrder   Int      @default(0)
  // False hides the dimension from the Life Matrix + radar + insights
  // UI. Underlying extraction still runs against all 6 canonical areas
  // (no data is lost if the user re-enables later).
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([userId, area])
  @@index([userId])
}

// Calendar integration stub. One row per connected calendar provider
// per user. The OAuth flow, token storage, and event-read pipeline
// ship post-beta — see docs/CALENDAR_INTEGRATION_PLAN.md — but the
// table exists now so /account can surface the connect state and
// writes stay compatible once the flows land.
//
// provider: "GOOGLE" | "OUTLOOK" | "APPLE" (CalDAV). String (not enum)
// for cross-Postgres compatibility, same pattern as other status
// columns. accessToken / refreshToken are nullable + intended to be
// encrypted at rest by a KMS wrapper that lands with the OAuth flow.
model CalendarConnection {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  provider     String
  // Provider-side account identifier (google sub, outlook oid, apple
  // principal URL). Unique per provider so the same user re-connecting
  // the same account is a no-op upsert.
  providerAccountId String
  accessToken  String?  @db.Text
  refreshToken String?  @db.Text
  tokenExpiresAt DateTime?
  // Last time we pulled events from this provider. Drives the
  // "Last synced" copy in /account and lets the ingest cron decide
  // when to re-fetch.
  lastSyncedAt DateTime?
  // When non-null, the connection is broken (revoked token, expired
  // refresh, etc.) — /account shows a "Reconnect" CTA.
  lastErrorAt  DateTime?
  lastError    String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([userId, provider])
  @@unique([provider, providerAccountId])
  @@index([userId])
}

// Quarterly State-of-Me report. Triggered every 90 days from signup
// by a scheduled Inngest function, OR manually from /insights (rate-
// limited to 1 per 30 days). Heavy Claude Opus 4.7 output — ~1,000
// words of narrative + structured fields for the UI.
//
// Share link (publicShareId) mirrors the WeeklyReport pattern; a
// 22-char random token enables the /shared/state-of-me/[publicId]
// public read-only view.
model StateOfMeReport {
  id              String   @id @default(cuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  // Inclusive period the report covers — typically [signup + 90N, now].
  periodStart     DateTime
  periodEnd       DateTime
  // Full content bundle. Schema lives in
  // packages/shared/src/types.ts::StateOfMeContent — narrative
  // reflection + themes + emotional arc + life-matrix delta + goals
  // progress + key relationships + patterns-noticed + closing.
  content         Json
  // Valid: "QUEUED" | "GENERATING" | "COMPLETE" | "FAILED".
  status          String   @default("QUEUED")
  errorMessage    String?
  inngestRunId    String?
  degraded        Boolean  @default(false)
  // Public share link — same shape as WeeklyReport's.
  publicShareId        String?   @unique
  publicShareExpiresAt DateTime?
  publicShareViewCount Int       @default(0)
  createdAt       DateTime @default(now())

  @@index([userId, createdAt])
}

// ─── Feature flags ──────────────────────────────────────────────────────────
//
// Runtime-togglable gates for the 13 named features the admin can
// enable/disable without a deploy. Evaluation order at lib/feature-
// flags.ts::isEnabled is:
//   1. UserFeatureOverride (user-specific force on/off)
//   2. FeatureFlag.enabled  (global kill switch)
//   3. rolloutPercentage    (deterministic hash(userId+key) < N)
//   4. requiredTier         (null = anyone, "FREE" / "PRO" = plan check)
//
// Disabled features should 404 on the API + hide in the UI — never 403
// (we don't want to leak the existence of a feature that's been pulled).
model FeatureFlag {
  id                 String   @id @default(cuid())
  // Short, URL-safe slug. Referenced from code by exact string, so
  // renames are a coordinated schema + code change.
  key                String   @unique
  // Human-readable name shown in the admin UI.
  name               String
  description        String?
  enabled            Boolean  @default(false)
  // 0..100. Only consulted when `enabled=true` and no user override
  // applies. 100 = everyone passes; 0 = no one passes unless the
  // global `enabled=true` AND `requiredTier` logic lets them through
  // (in practice 0 is a kill switch).
  rolloutPercentage  Int      @default(100)
  // Null = no tier gate. "FREE" or "PRO" restricts to users whose
  // User.subscriptionStatus matches the mapped tier.
  requiredTier       String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@index([key])
}

// Per-user override — forces a flag on or off for one account,
// bypassing rollout + tier logic. Used by admin "test this feature
// on my own row" workflows and for rapidly un-blocking a single
// affected user without flipping the global switch.
//
// No @relation to User — we want overrides to survive a Prisma
// cascade on User delete because audit history should reference
// the userId even after the account is gone. In practice the
// admin UI cleans stale rows.
model UserFeatureOverride {
  id        String   @id @default(cuid())
  userId    String
  flagKey   String
  enabled   Boolean
  // Short human note — required by the admin UI — so we have a
  // paper trail for "why is this user on feature X".
  reason    String
  createdAt DateTime @default(now())

  @@unique([userId, flagKey])
  @@index([userId])
  @@index([flagKey])
}

// Immutable audit log of every write an admin performs. Captures flag
// toggles, user overrides, trial extensions, soft-deletes, and magic-
// link resets. Never cascades on User delete — the admin's own row
// going away shouldn't erase the historical record of what they did.
//
// `action` is a short machine slug (e.g. "feature_flag.toggle"). The
// full event detail lives in `metadata` JSON. Use the helper at
// lib/admin-audit.ts::logAdminAction so slugs stay consistent.
model AdminAuditLog {
  id            String   @id @default(cuid())
  adminUserId   String
  action        String
  targetUserId  String?
  metadata      Json?
  createdAt     DateTime @default(now())

  @@index([adminUserId, createdAt])
  @@index([targetUserId])
  @@index([createdAt])
}
