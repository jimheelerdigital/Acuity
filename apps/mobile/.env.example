# apps/mobile/.env.example
#
# Copy to apps/mobile/.env and fill in real values for local dev.
# .env is gitignored at the repo root.
#
# For EAS Build: set these as EAS Secrets via the Expo dashboard
# (https://expo.dev → Acuity project → Configuration → Secrets).
# Without them, app.config.ts omits the react-native-fbsdk-next
# plugin block and the Meta SDK init no-ops at runtime.

# ─── Facebook / Meta SDK (ad attribution) ─────────────────────────
# Both required to compile the native FB SDK into the binary. The
# app ID is a public identifier (visible in the URL scheme post-
# build); the client token IS sensitive — never inline it in
# committed config or commit-message bodies.
EXPO_PUBLIC_FACEBOOK_APP_ID=
EXPO_PUBLIC_FACEBOOK_CLIENT_TOKEN=

# ─── Onboarding-v2 cold-launch routing ────────────────────────────
# Slice 13 (2026-05-26). Set to "true" to redirect unauthenticated
# cold-launches into the new pain-first flow at /onboarding-new/pain.
# Default false leaves the existing /(auth)/sign-in path active.
# Inlined into the JS bundle at build time — flipping in prod means
# flipping the env var + cutting a new EAS build OR an expo-updates
# OTA push.
EXPO_PUBLIC_NEW_ONBOARDING_ENABLED=false
