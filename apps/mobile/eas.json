      "env": {
        "EXPO_PUBLIC_API_URL": "http://localhost:3000"
      },
      "ios": {
        "simulator": true
      },
      "android": {
        "buildType": "apk"
      }
    },
    "preview": {
      "distribution": "internal",
      "channel": "preview",
      "autoIncrement": true,
      "env": {
        "EXPO_PUBLIC_API_URL": "https://goripple.io",
        "EXPO_PUBLIC_SENTRY_DSN": "https://c29c3ab6b17807b427a677cd5c518d1c@o4511258398818304.ingest.us.sentry.io/4511258441547776",
        "SENTRY_DISABLE_AUTO_UPLOAD": "true"
      },
      "ios": {
        "resourceClass": "m-medium"
      },
      "android": {
        "buildType": "apk"
      }
    },
    "production": {
      "distribution": "store",
      "channel": "production",
      "autoIncrement": true,
      "env": {
        "EXPO_PUBLIC_API_URL": "https://goripple.io",
        "EXPO_PUBLIC_SENTRY_DSN": "https://c29c3ab6b17807b427a677cd5c518d1c@o4511258398818304.ingest.us.sentry.io/4511258441547776",
