{
  "expo": {
    "name": "Acuity",
    "slug": "acuity",
    "version": "0.1.6",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "acuity",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#09090B"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.heelerdigital.acuity",
      "infoPlist": {
        "NSMicrophoneUsageDescription": "Acuity uses your microphone to record your daily voice entries.",
        "ITSAppUsesNonExemptEncryption": false,
        "CFBundleURLTypes": [
          {
            "CFBundleURLSchemes": [
              "com.googleusercontent.apps.657670168959-l1qn5imd2ad8fdbp96pius9a6cpi5hdl",
              "acuity"
            ]
          }
        ]
      },
      "config": {
        "usesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#09090B"
      },
      "package": "com.heelerdigital.acuity",
      "permissions": [
        "RECORD_AUDIO",
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS",
        "RECORD_AUDIO",
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS"
      ]
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-av",
        {
          "microphonePermission": "Acuity uses your microphone to record your daily voice entries."
        }
      ],
      [
        "expo-notifications",
        {
          "color": "#7C3AED"
        }
      ],
      [
        "@sentry/react-native/expo",
        {
          "organization": "heeler-digital",
          "project": "react-native",
          "url": "https://sentry.io/"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {
        "origin": false
      },
      "apiUrl": "https://www.getacuity.io",
      "googleIosClientId": "657670168959-l1qn5imd2ad8fdbp96pius9a6cpi5hdl.apps.googleusercontent.com",
      "eas": {
        "projectId": "dc4dcfc3-54f4-44e8-bc84-dfcedb8ba533"
      }
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/dc4dcfc3-54f4-44e8-bc84-dfcedb8ba533"
    }
  }
}
