        "backgroundColor": "#15131D"
      },
      "package": "com.heelerdigital.acuity",
      "permissions": [
        "RECORD_AUDIO",
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS",
        "RECORD_AUDIO",
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS"
      ]
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-av",
        {
          "microphonePermission": "Acuity uses your microphone to record your daily voice entries."
        }
      ],
      [
        "expo-notifications",
        {
          "color": "#7C3AED"
        }
      ],
      [
        "@sentry/react-native/expo",
        {
          "organization": "heeler-digital",
          "project": "react-native",
          "url": "https://sentry.io/"
        }
      ],
      "expo-web-browser",
      [
        "react-native-iap",
        {
          "ios": {
            "with-folly-no-coroutines": true
