    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#15131D"
      },
      "package": "com.heelerdigital.acuity",
      "versionCode": 1,
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS"
      ],
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "https",
              "host": "getacuity.io",
              "pathPrefix": "/api/auth/verify-email"
            }
          ],
          "category": ["BROWSABLE", "DEFAULT"]
        }
      ]
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "@react-native-community/datetimepicker",
      [
        "expo-av",
        {
          "microphonePermission": "Acuity uses your microphone to record voice entries, which are transcribed and analyzed to surface themes, tasks, and insights from what you said."
        }
      ],
      [
        "expo-notifications",
        {
          "color": "#7C3AED"
        }
      ],
      [
        "@sentry/react-native/expo",
        {
          "organization": "heeler-digital",
          "project": "react-native",
          "url": "https://sentry.io/"
        }
      ],
      "expo-web-browser",
      [
        "react-native-iap",
        {
          "ios": {
            "with-folly-no-coroutines": true
          }
        }
      ],
      [
        "expo-tracking-transparency",
        {
          "userTrackingPermission": "Acuity uses this only to help us see which Facebook or Instagram ads led you here, so we can keep showing the ones that actually helped. You can decline — nothing in the app changes."
        }
      ],
      "./plugins/with-folly-mobile-flag.js"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {
        "origin": false
      },
      "apiUrl": "https://getacuity.io",
      "googleIosClientId": "657670168959-l1qn5imd2ad8fdbp96pius9a6cpi5hdl.apps.googleusercontent.com",
      "iapEnabled": true,
      "facebookPixelId": "869829585445303",
      "eas": {
        "projectId": "dc4dcfc3-54f4-44e8-bc84-dfcedb8ba533"
      }
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/dc4dcfc3-54f4-44e8-bc84-dfcedb8ba533"
    }
  }
