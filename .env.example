# ─── Database (Supabase Postgres) ─────────────────────────────────────────────
DATABASE_URL="postgresql://postgres:[PASSWORD]@db.[PROJECT_REF].supabase.co:5432/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres:[PASSWORD]@db.[PROJECT_REF].supabase.co:5432/postgres"

# ─── Supabase ─────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL="https://[PROJECT_REF].supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY=""
SUPABASE_SERVICE_ROLE_KEY=""
SUPABASE_STORAGE_BUCKET="acuity-audio"

# ─── Auth (NextAuth) ──────────────────────────────────────────────────────────
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET=""                    # openssl rand -base64 32

# ─── Google OAuth ─────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# ─── Email / Magic Link (Resend SMTP) ─────────────────────────────────────────
EMAIL_SERVER_HOST="smtp.resend.com"
EMAIL_SERVER_PORT="465"
EMAIL_SERVER_USER="resend"
EMAIL_SERVER_PASSWORD=""              # Resend API key
EMAIL_FROM="Acuity <noreply@acuity.app>"

# ─── AI ───────────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=""
OPENAI_API_KEY=""

# ─── Stripe ───────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""
STRIPE_PRO_PRICE_ID=""

# ─── Expo / Mobile ────────────────────────────────────────────────────────────
EXPO_PUBLIC_API_URL="http://localhost:3000"
EXPO_PUBLIC_SUPABASE_URL="https://[PROJECT_REF].supabase.co"
EXPO_PUBLIC_SUPABASE_ANON_KEY=""

# ─── Rate limiting (Upstash Redis) ────────────────────────────────────────────
# Add via Vercel marketplace → Upstash, OR manually via upstash.com free tier
# (10K commands/day free). When unset the limiters fail-open with a one-time
# warning; S5 requires these set before public beta.
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# ─── Inngest (background jobs) ────────────────────────────────────────────────
# Copy INNGEST_EVENT_KEY + INNGEST_SIGNING_KEY from Inngest Cloud dashboard
# (Apps → acuity → <env> → API Keys). Set ENABLE_INNGEST_PIPELINE="1" to
# activate the /api/inngest handler — unset or "0" returns 503, keeping
# the endpoint safely inert during migration.
INNGEST_EVENT_KEY=""
INNGEST_SIGNING_KEY=""
ENABLE_INNGEST_PIPELINE=""
