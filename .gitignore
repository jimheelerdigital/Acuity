# Dependencies
node_modules/
.pnp
.pnp.js

# Build outputs
.next/
dist/
build/
out/

# Env files — ignore everything .env*, track only .env.example
.env
.env.*
!.env.example

# Secrets / keys / OAuth tokens
*.pem
*.p12
*.key
credentials.json
token.json
# google-services.json (apps/mobile) is intentionally COMMITTED — the Firebase
# Android client config (FCM), restricted by package + SHA-1 and shipped in the
# APK. It must NOT be gitignored: EAS Build filters .gitignore patterns out of
# the build archive even for tracked files (caused
# EAS_BUILD_MISSING_GOOGLE_SERVICES_JSON_ERROR on AAB #2). Allowlisted in
# .gitleaks.toml.
GoogleService-Info.plist
# Per-app secret stashes — never commit any file under apps/*/secrets/.
# Currently used by apps/mobile/secrets/play-service-account.json
# (Google Play Console submission credential).
apps/*/secrets/

# Terraform state with secrets
*.tfvars

# Prisma
prisma/migrations/

# Turbo
.turbo/

# OS
.DS_Store
Thumbs.db

# Logs
*.log
npm-debug.log*

# TypeScript
*.tsbuildinfo

# Expo
.expo/
apps/mobile/.expo/
apps/mobile/android/
apps/mobile/ios/
apps/mobile/dist/

# Editor
.vscode/
.idea/
*.swp
.vercel
.env*.local

# Visual-audit screenshots (scripts/visual-audit.ts) — contain real
# user data from AUDIT_USER_ID and regenerate per run.
.tmp/

# Android-launch suppression list — real bounced/unsubscribed addresses
# exported from Resend. Never commit real user emails.
apps/web/scripts/android-launch-suppression.txt
